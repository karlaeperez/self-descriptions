{
    "frames": {
        "study-intro": {
            "kind": "exp-lookit-text",
            "blocks": [
                {
                    "emph": true,
                    "text": "In a few moments, your child will meet Karla--a new game-maker here on Children Helping Science! Karla wants to get to know the children on Children Helping Science better and would love to learn 12 facts about them.",
                    "title": "Tell me about yourself!"
                },
                {
                    "text": "To help Karla get to know the kids on Children Helping Science better, your child will share 12 facts about themselves. Then, your child will name 12 animals."
                }
            ],
            "showPreviousButton": false
        },
        "instructions": {
            "kind": "exp-lookit-instructions",
            "blocks": [
                {
                    "title": "1. Overview of how to participate in this study",
                    "listblocks": [
                        {
                            "text": "First, you will use your webcam to read a consent form and agree to participate."
                        }
                    ]
                },
                {
                    "text": "Please try playing this sample audio to make sure you'll be able to hear the story.",
                    "title": "2. Adjust your speakers",
                    "mediaBlock": {
                        "text": "You should hear 'Ready to go!'",
                        "isVideo": false,
                        "sources": [
                            {
                                "src": "https://s3.amazonaws.com/lookitcontents/exp-physics-final/audio/ready.mp3",
                                "type": "audio/mp3"
                            },
                            {
                                "src": "https://s3.amazonaws.com/lookitcontents/exp-physics-final/audio/ready.ogg",
                                "type": "audio/ogg"
                            }
                        ],
                        "mustPlay": true,
                        "warningText": "Please try playing the sample audio."
                    }
                }
            ],
            "showWebcam": true,
            "webcamBlocks": [
                {
                    "title": "3. Make sure we can see you",
                    "listblocks": [
                        {
                            "text": "Take a look at your webcam view above. Get comfy, and adjust your own position or the computer as needed so both you and your child are visible."
                        },
                        {
                            "text": "This isn't a Zoom call - no one in the lab can see you - but the recorded video of your consent will be sent to the lab."
                        }
                    ]
                }
            ],
            "nextButtonText": "Next"
        },
        "video-config": {
            "kind": "exp-video-config",
            "troubleshootingIntro": ""
        },
        "video-consent": {
            "kind": "exp-lookit-video-consent",
            "PIName": "Hyowon Gweon",
            "datause": "A research assistant will collect your child's responses and review your video consent.",
            "payment": "After you finish the study, we will email you a $5 Amazon.com gift card within a week of participation. To be eligible for the gift card your child must be in the age range for this study and you need to submit a valid consent statement where we need to see that there is a child with you. There are no other direct benefits to you or your child from participating, but we hope you will enjoy the experience.",
            "purpose": "We are interested in what children know about self-disclosure. That is, how do children tell others about themselves?",
            "PIContact": "Hyowon Gweon (contact: sll_lookit@stanford.edu)",
            "procedures": "You and your child will help Karla get to know the kids on Children Helping Science. There are no anticipated risks associated with participating.",
            "institution": "Stanford University"
        },
