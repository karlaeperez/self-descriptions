#!/bin/sh

MAX_SIZE=$((100 * 1024 * 1024))  # 100MB in bytes

for file in $(git diff --cached --name-only); do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file")
    if [ "$size" -gt "$MAX_SIZE" ]; then
      echo "Excluding $file from commit ($(( size / 1024 / 1024 ))MB exceeds 100MB limit)"
      git reset HEAD "$file"
    fi
  fi
done
